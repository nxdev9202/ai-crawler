{
  "manifest_version": 3,
  "name": "NX 쿠키 전송",
  "version": "1.0.0",
  "description": "쿠팡·네이버 로그인 세션 쿠키를 NX AI 크롤러로 버튼 한 번에 전송합니다.",
  "permissions": ["cookies", "storage"],
  "host_permissions": [
    "*://*.coupang.com/*",
    "*://*.naver.com/*",
    "http://127.0.0.1/*",
    "http://localhost/*"
  ],
  "action": {
    "default_popup": "popup.html",
    "default_title": "NX 쿠키 전송",
    "default_icon": {
      "16": "icon16.png",
      "48": "icon48.png",
      "128": "icon128.png"
    }
  },
  "icons": {
    "16": "icon16.png",
    "48": "icon48.png",
    "128": "icon128.png"
  }
}
