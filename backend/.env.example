# 데이터베이스 (기본: SQLite, 서버 불필요)
# 비워두면 backend/app.db (SQLite) 사용 (서버 불필요)

# Google AI (Gemini) API 키 - https://aistudio.google.com/apikey 에서 발급
GOOGLE_API_KEY=여기에_발급받은_키_붙여넣기
GEMINI_MODEL=gemini-2.0-flash

# 크롤러 설정
CRAWL_MAX_PRODUCTS=10          # 검색 1페이지에서 상세페이지 진입할 최대 상품 수
REVIEW_MAX=300                # 상품당 수집할 리뷰 최대 개수(20개씩 페이지네이션)
CRAWL_HEADLESS=false          # 네이버는 headless 차단 → false(창 표시) 필수. 쿠팡만 쓸 땐 true 가능

# 자동 로그인용 자격증명 (로그인 세션 없을 때 사용)
NAVER_ID=
NAVER_PW=
COUPANG_EMAIL=
COUPANG_PW=
CRAWL_MIN_DELAY_MS=800        # 요청 사이 최소 지연(ms) - 봇 차단 완화
CRAWL_MAX_DELAY_MS=2200       # 요청 사이 최대 지연(ms)
CRAWL_NAV_TIMEOUT_MS=30000    # 페이지 이동 타임아웃(ms)

# (선택) 평소 쓰는 크롬 프로필 재사용 - 이미 네이버/쿠팡 로그인돼 있으면 로그인 생략
#  주의: 크롤링 중 평소 크롬을 완전히 종료해야 함(프로필 잠금)
#  비워두면 전용 프로필(backend/.userdata) 사용 (권장)
# CRAWL_CHROME_USER_DATA_DIR=/Users/scarpula/Library/Application Support/Google/Chrome
# CRAWL_CHROME_PROFILE=Default

# 서버
BACKEND_HOST=127.0.0.1
BACKEND_PORT=8756

# (선택) 프록시 - 회사 공인 IP 보호. residential/모바일 프록시 권장(데이터센터 X).
# 비워두면 프록시 비활성(현재 상태). 아래를 채우면 크롤·로그인·리뷰 전부 프록시 경유.
# PROXY_SERVER=http://gate.provider.com:7000
# PROXY_USERNAME=발급유저명
# PROXY_PASSWORD=발급비번
# 크롤 단위 sticky IP(검색어마다 새 IP, 세션 내 고정)를 쓰려면 username에 {session} 토큰 사용:
# 예) PROXY_USERNAME=user-session-{session}   → 크롤마다 자동으로 다른 세션ID로 치환됨
